# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose configuration. Copy this file to ".env" and edit the values:
#     cp .env.example .env
# docker compose автоматически подхватит .env из этой папки.
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL (используется и базой, и бэкендом) ---------------------------
POSTGRES_USER=turizm
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=turizm

# --- Backend security --------------------------------------------------------
# Случайная строка для подписи JWT. Сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256

# Загрузить демо-отели при первом старте (1 = да, 0 = нет).
SEED_DEMO=0

# --- Web (значения вшиваются в сборку фронтенда) -----------------------------
# Относительный путь -> фронт ходит на тот же домен, nginx проксирует на backend.
# Менять не нужно для стандартного развёртывания.
VITE_API_URL=/api/v1
# Google OAuth Client ID (если нужна кнопка "Войти через Google"); иначе пусто.
VITE_GOOGLE_CLIENT_ID=

# Порт на сервере, на котором будет доступен сайт (по умолчанию 80).
WEB_PORT=80
